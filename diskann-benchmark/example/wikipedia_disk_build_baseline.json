{
  "search_directories": [
    "C:/wikipedia_dataset"
  ],
  "jobs": [
    {
      "type": "disk-index",
      "content": {
        "source": {
          "disk-index-source": "Build",
          "data_type": "float32",
          "data": "C:/wikipedia_dataset/data.bin",
          "distance": "squared_l2",
          "dim": 1024,
          "max_degree": 64,
          "l_build": 100,
          "num_threads": 8,
          "build_ram_limit_gb": 32.0,
          "num_pq_chunks": 128,
          "quantization_type": "FP",
          "save_path": "C:/wikipedia_dataset/wikipedia_saved_disk_index"
        },
        "search_phase": {
          "queries": "C:/wikipedia_dataset/query.bin",
          "groundtruth": "C:/wikipedia_dataset/groundtruth_k100.bin",
          "search_list": [20, 30, 40, 50, 100, 200],
          "beam_width": 8,
          "recall_at": 10,
          "num_threads": 8,
          "is_flat_search": false,
          "distance": "squared_l2",
          "vector_filters_file": null
        }
      }
    }
  ]
}
