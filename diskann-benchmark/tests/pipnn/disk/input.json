{
  "search_directories": ["$WORKSPACE/test_data/disk_index_search"],
  "jobs": [
    {
      "type": "disk-index",
      "content": {
        "source": {
          "disk-index-source": "Build",
          "data_type": "float32",
          "data": "disk_index_siftsmall_learn_256pts_data.fbin",
          "distance": "squared_l2",
          "dim": 128,
          "max_degree": 32,
          "l_build": 50,
          "num_threads": 1,
          "build_ram_limit_gb": 2.0,
          "num_pq_chunks": 128,
          "quantization_type": "FP",
          "build_algorithm": {
            "algorithm": "PiPNN",
            "num_hash_planes": 14,
            "c_max": 512,
            "c_min": 64,
            "p_samp": 0.01,
            "fanout": [10, 3],
            "k": 2,
            "replicas": 1,
            "l_max": 72,
            "final_prune": true
          },
          "save_path": "$TEMPDIR/pipnn-index"
        },
        "search_phase": {
          "queries": "disk_index_sample_query_10pts.fbin",
          "groundtruth": "disk_index_10pts_idx_uint32_truth_search_res.bin",
          "search_list": [20],
          "beam_width": 4,
          "recall_at": 10,
          "num_threads": 1,
          "is_flat_search": false,
          "distance": "squared_l2",
          "vector_filters_file": null
        }
      }
    }
  ]
}
