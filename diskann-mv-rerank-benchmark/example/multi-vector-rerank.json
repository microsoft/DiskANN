{
  "search_directories": [
    "multivector_data/arguana/diskann"
  ],
  "output_directory": "multivector_data/arguana/diskann",
  "jobs": [
    {
      "type": "multi-vector-rerank-build",
      "content": {
        "source": {
          "index-source": "Build",
          "data_type": "float32",
          "data": "arguana_docs.fbin",
          "distance": "inner_product",
          "max_degree": 32,
          "l_build": 64,
          "alpha": 1.2,
          "backedge_ratio": 1.0,
          "num_threads": 30,
          "start_point_strategy": "medoid",
          "save_path": "arguana_graph"
        },
        "search": {
          "queries": "arguana_queries_dev.fbin",
          "groundtruth": "arguana_gt.bin",
          "reps": 1,
          "num_threads": [30],
          "runs": [
            {
              "search_n": 10,
              "search_l": [10, 50, 100, 200, 500]
            }
          ]
        },
        "doc_mv": "arguana_docs.mvbin",
        "query_mv": "arguana_queries_dev.mvbin"
      }
    },
    {
      "type": "multi-vector-rerank-build",
      "content": {
        "source": {
          "index-source": "Load",
          "data_type": "float32",
          "distance": "inner_product",
          "load_path": "arguana_graph"
        },
        "search": {
          "queries": "arguana_queries_dev.fbin",
          "groundtruth": "arguana_gt.bin",
          "reps": 1,
          "num_threads": [30],
          "runs": [
            {
              "search_n": 10,
              "search_l": [10, 50, 100, 200, 500]
            }
          ]
        },
        "doc_mv": "arguana_docs.mvbin",
        "query_mv": "arguana_queries_dev.mvbin"
      }
    }
  ]
}
